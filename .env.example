# ──────────────────────────────────────────────────────────────────────────────
# Supabase Debug Playground — Environment Variables
# Copy this file to .env and fill in values from `pnpm supabase:start` output
# ──────────────────────────────────────────────────────────────────────────────

# From `supabase start` → API URL (default local: http://127.0.0.1:54321)
SUPABASE_URL=http://127.0.0.1:54321

# From `supabase start` → anon key
SUPABASE_ANON_KEY=your-anon-key-here

# From `supabase start` → service_role key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ── EP6 — Production deployment (real Supabase project) ──────────────────────
# Required only for Episode 6 (Local to Production)
# SUPABASE_PROJECT_REF=your-project-ref          # from Supabase project settings URL
# SUPABASE_ACCESS_TOKEN=your-access-token        # from supabase.com/dashboard/account/tokens
# PROD_SUPABASE_URL=https://your-project-ref.supabase.co
# PROD_SUPABASE_ANON_KEY=your-prod-anon-key      # from project API settings
